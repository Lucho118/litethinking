# ai-agent/.env — copia de .env.example, completa con tu OPENAI_API_KEY
# Nunca commitear este archivo con la key real.

# === OpenAI ===
OPENAI_API_KEY=                                    # ← pega aquí tu key
OPENAI_EMBEDDING_MODEL=text-embedding-3-small      # 1536 dimensiones, más económico
OPENAI_CHAT_MODEL=gpt-4o-mini                      # costo/calidad óptimo para prueba técnica

# === Base de datos (misma que backend/) ===
# Sin DATABASE_URL → no se conecta (el servidor arranca igual, /agente/consulta devuelve 503)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/litethinking

# === Parámetros RAG ===
TOP_K_RESULTS=5          # productos recuperados por consulta (controla costo del prompt)
EMBEDDING_DIMENSION=1536 # debe coincidir con OPENAI_EMBEDDING_MODEL
