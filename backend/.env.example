# Copy this file to .env and fill in real values. Never commit .env.
SECRET_KEY=django-insecure-replace-this-with-a-real-secret-key
DEBUG=True

# DATABASE_URL — opcional:
#   Definida  → Django usa esa BD (PostgreSQL, MySQL, etc.)
#   Ausente   → Django usa SQLite automáticamente (db.sqlite3 en backend/)
#
# Con PostgreSQL:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/litethinking
#
# Sin PostgreSQL (comentar o eliminar la línea de arriba):
# (no definir DATABASE_URL → SQLite)

CORS_ALLOWED_ORIGINS=http://localhost:3000
AI_AGENT_URL=http://localhost:8001

# ── Email (Gmail SMTP) ───────────────────────────────────────────────────────
# Genera un App Password en: Cuenta Google → Seguridad → Contraseñas de aplicaciones
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tu_correo@gmail.com
EMAIL_HOST_PASSWORD=tu_app_password_aqui
DEFAULT_FROM_EMAIL=LiteThinking <tu_correo@gmail.com>
